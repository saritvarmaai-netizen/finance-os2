generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id             String         @id @default(cuid())
  bank           String
  name           String
  entity         String
  balance        Float
  monthlyInflow  Float          @default(0)
  monthlyOutflow Float          @default(0)
  isAutoFD       Boolean        @default(false)
  isClubbed      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  fixedDeposits  FixedDeposit[]
}

model FixedDeposit {
  id             String   @id @default(cuid())
  accountId      String
  entity         String
  principal      Float
  rate           Float
  startDate      String
  maturityDate   String
  maturityAmount Float
  daysLeft       Int      @default(0)
  tdsExpected    Float    @default(0)
  isAutoFD       Boolean  @default(false)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Transaction {
  id           String   @id @default(cuid())
  date         String
  description  String
  account      String
  category     String
  debit        Float    @default(0)
  credit       Float    @default(0)
  entity       String
  aiConfidence Int      @default(0)
  isTransfer   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MFHolding {
  id         String   @id @default(cuid())
  name       String
  amc        String
  category   String
  entity     String
  units      Float
  avgNAV     Float
  currentNAV Float
  xirr       Float    @default(0)
  taxType    String   @default("LTCG")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShareHolding {
  id         String   @id @default(cuid())
  symbol     String
  company    String
  exchange   String
  sector     String
  entity     String
  qty        Int
  avgPrice   Float
  cmp        Float
  dividendFY Float    @default(0)
  taxType    String   @default("LTCG")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  priority  String   @default("normal")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
